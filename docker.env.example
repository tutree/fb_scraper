# Stack Ports
API_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_USER=scraper
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=math_tutor_db

# App Settings
# HEADLESS=false runs Chromium with a virtual display (Xvfb) so hover tooltips work like on desktop; set true for headless-only
HEADLESS=false
API_V1_PREFIX=/api/v1
PROJECT_NAME=Math Tutor Scraper API
DEBUG=false
MAX_RESULTS_PER_KEYWORD=30
SCRAPE_DELAY_MIN=3
SCRAPE_DELAY_MAX=8
MAX_RETRIES=3

# Integrations / Credentials
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=
PROXY_LIST=
AI_PROVIDER=ollama
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_PORT=11434

# EnformionGO Contact Enrichment (https://enformiongo.readme.io)
ENFORMION_AP_NAME=
ENFORMION_AP_PASSWORD=

# 2Captcha (for Facebook login captcha solving — optional)
CAPTCHA_2CAPTCHA_API_KEY=

# Background Automation (uses config/keywords.json; starts automatically)
AUTO_SCRAPE_ENABLED=true
AUTO_SCRAPE_INTERVAL_MINUTES=180
AUTO_SCRAPE_MAX_RESULTS=30
AUTO_ANALYZE_AFTER_SCRAPE=true
AUTO_ENRICH_AFTER_ANALYZE=true
