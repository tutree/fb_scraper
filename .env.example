# Database Configuration
DATABASE_URL=postgresql://scraper:scraper123@localhost:5432/math_tutor_db
REDIS_URL=redis://localhost:6379

# Facebook Account Credentials
# Use UID (numeric ID) or email as username
FACEBOOK_EMAIL=your_facebook_uid_or_email
FACEBOOK_PASSWORD=your_password

# Proxy Configuration
# SSH Tunnel: ssh -D 1080 shakil@100.85.92.28
# This creates a SOCKS5 proxy on your local PC at 127.0.0.1:1080
# Docker containers access it via host.docker.internal:1080
PROXY_LIST=socks5://host.docker.internal:1080
