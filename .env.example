# Database Configuration
DATABASE_URL=postgresql://scraper:scraper123@localhost:5432/math_tutor_db
REDIS_URL=redis://localhost:6379
# GEMINI_API_KEY=
# Facebook Account Credentials
# Use UID (numeric ID) or email as username
FACEBOOK_EMAIL=your_facebook_uid_or_email
FACEBOOK_PASSWORD=your_password

# Proxy Configuration — comma-separated. With multiple Facebook accounts (tabs), the 1st URL is used for
# Account 1, 2nd for Account 2, etc. (wrap in quotes if URLs contain commas.)
# Example: PROXY_LIST=socks5://host:1080,socks5://host:1081
PROXY_LIST=socks5://host.docker.internal:1080

# Facebook search: toggle "Posts You've Seen" to reduce repeat posts (default true)
# FB_SEARCH_ENABLE_POSTS_SEEN_FILTER=false

# Scraper: only use saved cookies unless true (password/captcha login is never attempted when false)
# FB_TRY_CREDENTIAL_LOGIN=false

# Writable keywords.json (required in Docker if ./config is bind-mounted read-only or root-owned)
# KEYWORDS_FILE_PATH=/data/keywords.json

# Scheduled auto-scrape (off by default). Requires keywords in config/keywords.json (or KEYWORDS_FILE_PATH).
# AUTO_SCRAPE_ENABLED=true
# AUTO_SCRAPE_RUN_ON_STARTUP=false
# AUTO_SCRAPE_INTERVAL_MINUTES=180

# AI Provider: groq (default) or gemini
AI_PROVIDER=groq
GEMINI_API_KEY=
# Comma-separated: first key is used; on 401/403 the next key is tried automatically
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Seconds between Groq calls (global). Increase if you see HTTP 429 in logs.
GROQ_MIN_INTERVAL_SECONDS=3.5
